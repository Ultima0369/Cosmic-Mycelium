# EditorConfig — Consistent coding styles across editors
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Python files
[*.py]
max_line_length = 88
indent_size = 4

# Python type stub files
[*.pyi]
max_line_length = 88
indent_size = 4

# Jupyter notebooks
[*.ipynb]
indent_size = 4

# YAML files
[*.{yaml,yml}]
indent_size = 2

# TOML files
[*.toml]
indent_size = 2

# JSON files (keep as-is)
[*.json]
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Shell scripts
[*.sh]
indent_style = tab
indent_size = 4

# Dockerfile
[Dockerfile]
indent_style = space
indent_size = 4

# CI configurations
[*.yml]
indent_size = 2

# Commit message (no max line, conventional format)
[COMMIT_MSG]
max_line_length = 100

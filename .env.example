# Cosmic Mycelium — Environment Configuration Template
# Copy this file to .env and adjust values for your deployment.
# Defaults are provided for local development.

# =============================================================================
# Core Identity
# =============================================================================
COSMIC_ENV=development                    # Environment name (development/staging/production)
INFANT_ID=infant-001                      # Unique infant node identifier
INFANT_NODE_ROLE=standalone               # Node role (standalone/cluster/global)

# =============================================================================
# HIC Energy Management
# =============================================================================
INFANT_ENERGY_MAX=100.0                   # Maximum HIC energy capacity
INFANT_CONTRACT_DURATION=0.055            # Contract phase duration (seconds)
INFANT_DIFFUSE_DURATION=0.005             # Diffuse phase duration (seconds)
INFANT_SUSPEND_DURATION=5.0              # Suspend phase duration (seconds)
INFANT_RECOVERY_ENERGY=60.0              # Energy threshold for recovery phase
INFANT_RECOVERY_RATE=0.5                 # Recovery rate per second

# =============================================================================
# Physics Anchor Thresholds
# =============================================================================
PHYSICS_ENERGY_DRIFT_MAX=0.001           # Max allowed energy drift ratio (< 0.1%)
PHYSICS_ADAPTATION_THRESHOLD=0.001       # Adaptation trigger threshold

# =============================================================================
# Service Endpoints
# =============================================================================
REDIS_URL=redis://redis:6379/0           # Redis connection URL
KAFKA_BOOTSTRAP_SERVERS=kafka:9092      # Kafka bootstrap servers (comma-separated for multiple)

# =============================================================================
# Observability
# =============================================================================
LOG_LEVEL=INFO                            # Logging level (DEBUG/INFO/WARNING/ERROR)
METRICS_PORT=8000                        # Prometheus metrics endpoint port
HEALTH_PORT=8001                         # Health check endpoint port

# =============================================================================
# Data Persistence
# =============================================================================
COSMIC_MYCELIUM_DATA_DIR=/app/data       # Persistent data directory
COSMIC_MYCELIUM_LOG_DIR=/app/logs        # Log directory

# =============================================================================
# Optional: Advanced Configuration
# =============================================================================
# INFANT_PROFILE=dev                      # Profile: dev (hot reload) or prod (no debug)
# INFANT_EMBEDDING_DIM=16                 # Override default embedding dimension
# INFANT_NUM_SPORES=10                    # Override default spore count
# INFANT_MAX_TRACES=10000                 # Override memory trace capacity

.env
.env.local
.env.*.local

# Spyder project
.spyderproject
.spyproject

# Rope project
.ropeproject

# Docker
docker-compose.override.yml

# CI/CD
.reports/
junit.xml
test-results.xml

# Secrets detection
.secrets.baseline

# Monitoring data
monitoring/prometheus/data/
monitoring/grafana/data/


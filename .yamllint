# YAML Lint Configuration for Cosmic Mycelium
# Ensures all YAML files are well-formed and follow style conventions

extends: default

rules:
  # Document rules
  document-start: enable  # All YAML files must start with '---'
  truthy: enable  # 'yes', 'no', 'on', 'off' are not allowed (use true/false)

  # Line rules
  line-length:
    max: 88
    allow-non-breakable-words: true
    allow-non-breakable-inline-mappings: true

  # Key rules
  key-duplicates: enable
  key-ordering: enable

  # Value rules
  empty-values: enable
  hyphens: enable
  commas: enable

  # Indentation rules
  indentation:
    indent-sequences: consistent
    spaces: 2

  # Trailing spaces
  trailing-spaces: enable

  # New line rules
  new-line-at-end-of-file: enable

  # Comments rules
  comments:
    level: warning
    require-starting-space: true
    ignore-shebangs: true

# Exclude files
ignore: |
  .git/
  .venv/
  venv/
  build/
  dist/
  __pycache__/
  *.egg-info/
  node_modules/
  .pytest_cache/
  .mypy_cache/
  .ruff_cache/
  htmlcov/
  .coverage
  coverage.xml
  .secrets.baseline
